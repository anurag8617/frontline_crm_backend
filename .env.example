PORT=3001
NODE_ENV=production

# MySQL Database connection details
# IMPORTANT: When deploying to Render, use the EXTERNAL host from Railway (e.g., roundhouse.proxy.rlwy.net)
# Do NOT use mysql.railway.internal (that is for internal Railway use only)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=frontline
DB_SSL=true

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_64_CHARACTER_HEX_STRING
JWT_EXPIRES_IN=7d

# Gmail SMTP — use an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=frontlineislandbarandgrill1@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD_HERE
SMTP_FROM_NAME=Frontline Island Bar & Grill
SMTP_FROM_EMAIL=frontlineislandbarandgrill1@gmail.com

# Netlify URL for CORS
FRONTEND_URL=https://frontlineislandbar.netlify.app/
